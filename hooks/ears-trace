#!/bin/bash
# EARS — Experience And Reasoning System (v7)
#
# State-machine hook that captures problem-solving *moments*, not edit counts.
#
# Seven triggers:
#   1. SESSION-START: First tool call of a session — capture task context.
#   2. ERROR→FIX: A Bash command fails, then a similar command succeeds
#      within 5 minutes. Prompts on the FIX (not the error — too early).
#   3. STUCK: Same file edited 4+ times in 20 recent edits (thrashing).
#   4. COMMIT-DIGEST: On git commit, includes diff summary + commit message
#      so the agent can reflect on WHAT was committed. No rate-limit — each
#      commit is a natural boundary.
#   5. SESSION-END: On git merge or wrap-up commands (rate-limited).
#      Includes DISTILL-NUDGE and MEMORY-NUDGE: prompts agent to check
#      whether any findings should be written to .claude/memory/.
#   6. ACTIVITY-PULSE: 30+ min of active edits without a commit or trace
#      update — nudges the agent to capture decisions in-flight.
#
# v7 changes:
#   - SESSION-END now includes MEMORY-NUDGE: after writing trace, the agent
#     is prompted to check if any pitfalls/decisions/patterns should be
#     written to .claude/memory/*.yaml (the "reflect-lite" step).
#   - EARS core protocol documented in ~/.claude/CLAUDE.md (user-level).
#   - Project CLAUDE.md files only contain project-specific extensions.
#
# Design principle: The hook doesn't detect what's important. It provides
# context at the right moment. The AGENT decides what to write.
#
# Concept tagging: Every trace template includes <!-- concepts: ... -->
# for the agent to tag 1-3 knowledge areas. These tags are consumed by
# `pyasurf graph ingest` to connect findings to the knowledge graph.
#
# All triggers are rate-limited to at most once per 10 minutes each
# (except COMMIT-DIGEST, which fires on every commit).
#
# State lives in /tmp/ears_<context>/ as small files.
# Error→Fix uses a per-repo state dir (keyed by REPO_ROOT hash) so that
# the error and fix always share the same pending_error.json, even when
# they resolve to different TRACE_DIR contexts.
# Exit 2 + stderr = blocking feedback to the model.
# Exit 0 = silent pass-through.
#
# Session state lives in .claude/state/current.yaml (structured YAML).
# ${EARS_STATE} helper: ~/.local/bin/ears-state

EARS_STATE="${HOME}/.local/bin/ears-state"

set -uo pipefail

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null)
CWD=$(echo "$INPUT" | jq -r '.cwd // empty' 2>/dev/null)

[ -z "$TOOL" ] && exit 0
[ -z "$CWD" ] && exit 0

# ── Extract file path ─────────────────────────────────────────

FILE=""
CMD=""
case "$TOOL" in
    Write|Edit)
        FILE=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)
        ;;
    Bash)
        CMD=$(echo "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null)
        MATCH=$(echo "$CMD" | grep -oE '(papers|benchmarks|pyasurf|scripts|knowledge)/[^[:space:]"]+' | head -1)
        [ -n "$MATCH" ] && FILE="$CWD/$MATCH"
        ;;
esac

# Skip meta-files and trace.md self-edits
case "${FILE:-}" in
    */.claude/*|*/.git/*|*/__pycache__/*|*/node_modules/*|*.egg-info/*) exit 0 ;;
    */trace.md) exit 0 ;;
    */MEMORY.md|*/memory/*) exit 0 ;;
esac

# ── Find nearest trace.md or repo root ────────────────────────

TRACE_DIR=""
REPO_ROOT=""
for START in "$FILE" "$CWD"; do
    [ -z "$START" ] && continue
    DIR="$START"
    [ ! -d "$DIR" ] && DIR=$(dirname "$DIR" 2>/dev/null)
    while [ -n "$DIR" ] && [ "$DIR" != "/" ]; do
        if [ -f "$DIR/trace.md" ]; then
            TRACE_DIR="$DIR"
            break 2
        fi
        if [ -d "$DIR/.git" ] || [ -f "$DIR/.git" ]; then
            [ -z "$REPO_ROOT" ] && REPO_ROOT="$DIR"
            break
        fi
        DIR=$(dirname "$DIR")
    done
done

[ -z "$TRACE_DIR" ] && [ -z "$REPO_ROOT" ] && exit 0

CTX_NAME=$(basename "${TRACE_DIR:-$REPO_ROOT}")
STATE_DIR="/tmp/ears_${CTX_NAME}"
mkdir -p "$STATE_DIR"

# Per-repo state dir for Error→Fix (stable across contexts within one worktree)
if [ -n "$REPO_ROOT" ]; then
    REPO_HASH=$(echo "$REPO_ROOT" | md5sum | cut -c1-12)
else
    REPO_HASH=$(echo "$CWD" | md5sum | cut -c1-12)
fi
REPO_STATE_DIR="/tmp/ears_repo_${REPO_HASH}"
mkdir -p "$REPO_STATE_DIR"

# ── Helper: rate-limit a trigger (once per 10 min per tag) ────

rate_limited() {
    local TAG="$1"
    local LIMIT_FILE="$STATE_DIR/rate_${TAG}"
    local NOW
    NOW=$(date +%s)
    if [ -f "$LIMIT_FILE" ]; then
        local LAST
        LAST=$(cat "$LIMIT_FILE" 2>/dev/null || echo 0)
        if [ $((NOW - LAST)) -lt 600 ]; then
            return 0  # rate-limited
        fi
    fi
    echo "$NOW" > "$LIMIT_FILE"
    return 1  # not rate-limited
}

trace_path() {
    if [ -n "$TRACE_DIR" ]; then
        echo "$TRACE_DIR/trace.md"
    else
        echo "$REPO_ROOT/trace.md (create it)"
    fi
}

# ── SESSION-START: first tool call captures task context ────

SESSION_MARKER="$STATE_DIR/session_started"
if [ ! -f "$SESSION_MARKER" ]; then
    echo "$(date +%s)" > "$SESSION_MARKER"

    # Initialize session state (structured YAML)
    ${EARS_STATE} init 2>/dev/null || true

    # Only fire if trace.md exists (don't nag about missing trace on first call)
    if [ -n "$TRACE_DIR" ]; then
        cat >&2 <<MSG
[EARS] New session in $CTX_NAME.

Append to $(trace_path):
### EARS — Session Start ($(date '+%Y-%m-%d %H:%M'))
<!-- concepts: concept1, concept2 -->
- Task: <what did the user ask you to do? one line>
- Why: <what is the user's broader goal?>
(Tag concepts: name the 1-3 knowledge areas this session will touch.)
MSG
        exit 2
    fi
fi

# ============================================================
# BASH path: ERROR→FIX state machine + SESSION-END detection
# ============================================================

if [ "$TOOL" = "Bash" ]; then

    # Extract exit code — handle both object and string responses
    EXIT_CODE=$(echo "$INPUT" | jq -r '
        .tool_response |
        if type == "object" then (.exitCode // .exit_code // "0" | tostring)
        else "0" end
    ' 2>/dev/null)
    # Treat null/empty as success
    case "$EXIT_CODE" in
        ""|"null") EXIT_CODE="0" ;;
    esac

    # Command signature: first 3 tokens, for matching error→fix pairs
    CMD_SIG=$(echo "${CMD:-}" | sed 's/^[[:space:]]*//' | tr -s ' ' | cut -d' ' -f1-3 | head -c 80)

    # ── On error: record silently, wait for the fix ──
    if [ "$EXIT_CODE" != "0" ]; then
        # Extract error snippet from response
        ERR_SNIPPET=$(echo "$INPUT" | jq -r '
            .tool_response |
            if type == "object" then
                ((.stderr // "") + "\n" + (.stdout // "")) | tostring
            elif type == "string" then .
            else "" end
        ' 2>/dev/null | tail -c 500)

        jq -n \
            --arg sig "$CMD_SIG" \
            --arg err "$ERR_SNIPPET" \
            --arg ts "$(date +%s)" \
            --arg cmd "$(echo "${CMD:-}" | head -c 200)" \
            '{sig: $sig, error_snippet: $err, timestamp: $ts, command: $cmd}' \
            > "$REPO_STATE_DIR/pending_error.json" 2>/dev/null

        exit 0  # Silent — the error just happened, too early to reflect
    fi

    # ── On success: check if this resolves a pending error ──
    if [ -f "$REPO_STATE_DIR/pending_error.json" ]; then
        PREV_SIG=$(jq -r '.sig // ""' "$REPO_STATE_DIR/pending_error.json" 2>/dev/null)
        PREV_ERR=$(jq -r '.error_snippet // ""' "$REPO_STATE_DIR/pending_error.json" 2>/dev/null)
        PREV_CMD=$(jq -r '.command // ""' "$REPO_STATE_DIR/pending_error.json" 2>/dev/null)
        PREV_TS=$(jq -r '.timestamp // "0"' "$REPO_STATE_DIR/pending_error.json" 2>/dev/null)
        NOW=$(date +%s)
        AGE=$((NOW - PREV_TS))

        # Match criteria: same command prefix OR within 5 minutes
        RESOLVED=false
        if [ -n "$PREV_SIG" ] && [ -n "$CMD_SIG" ] && \
           echo "$CMD_SIG" | grep -qF "$(echo "$PREV_SIG" | cut -d' ' -f1)"; then
            RESOLVED=true
        elif [ "$AGE" -lt 300 ]; then
            RESOLVED=true
        fi

        if [ "$RESOLVED" = "true" ]; then
            rm -f "$REPO_STATE_DIR/pending_error.json"

            # Build short forms used by both the structured decision and the prompt
            SHORT_ERR=$(echo "$PREV_ERR" | tr '\n' ' ' | head -c 200)
            SHORT_CMD=$(echo "$PREV_CMD" | head -c 120)

            # Write structured decision to session state
            ${EARS_STATE} decision \
                --type error_fix \
                --summary "Fixed: ${CMD_SIG}" \
                --question "Error in: $(echo "$PREV_CMD" | head -c 80)" \
                --decision "$(echo "$CMD" | head -c 120)" \
                --rationale "$(echo "$SHORT_ERR" | head -c 120)" \
                2>/dev/null || true

            if rate_limited "error_fix"; then
                exit 0
            fi

            cat >&2 <<MSG
[EARS] Error→Fix in $CTX_NAME.
  Failed: $SHORT_CMD
  Error:  $SHORT_ERR
  Fixed:  $CMD_SIG ...

Append to $(trace_path):
### EARS — Error→Fix ($(date '+%Y-%m-%d %H:%M'))
<!-- concepts: concept1, concept2 -->
- Context: <what task/goal were you working on?>
- Failed: <the command/operation that failed>
- Error: <the error message>
- Root cause: <what was actually wrong>
- Fix: <what you changed>
- Lesson: <general principle to avoid this in the future>
(Tag concepts: name the 1-3 knowledge areas this belongs to, e.g. spherical-flames, pyasurf-solver, bohrium)
MSG
            exit 2
        fi

        # Expire stale pending errors after 10 minutes
        if [ "$AGE" -gt 600 ]; then
            rm -f "$REPO_STATE_DIR/pending_error.json"
        fi
    fi

    # ── COMMIT-DIGEST: content-aware reflection after git commit ──
    # Replaces the old content-blind SESSION-END.  On every commit, include
    # the diff summary + commit message so the agent knows WHAT to reflect on.
    # No rate-limit — each commit is a natural boundary worth capturing.
    CMD_FIRST=$(echo "${CMD:-}" | sed 's/^[[:space:]]*//' | cut -d' ' -f1)
    IS_COMMIT=false
    case "$CMD_FIRST" in
        git)
            case "${CMD:-}" in
                *"git commit"*) IS_COMMIT=true ;;
            esac
            ;;
    esac

    if [ "$IS_COMMIT" = "true" ]; then
        # Gather context: what was just committed?
        COMMIT_MSG=$(git -C "${REPO_ROOT:-$CWD}" log -1 --format='%s' 2>/dev/null | head -c 200)
        DIFF_STAT=$(git -C "${REPO_ROOT:-$CWD}" diff --stat HEAD~1 2>/dev/null | tail -8)

        # Update session state
        ${EARS_STATE} bump commits 2>/dev/null || true

        if [ -n "$COMMIT_MSG" ] && [ -n "$TRACE_DIR" ]; then
            cat >&2 <<MSG
[EARS] Commit in $CTX_NAME: $COMMIT_MSG

Changes:
$DIFF_STAT

Append to $(trace_path):
### EARS — Commit Digest ($(date '+%Y-%m-%d %H:%M'))
<!-- concepts: concept1, concept2 -->
Reflect on this commit. What decisions were made and why? What would help
a future agent (or you in 3 months) understand this change? Skip if trivial.
(Tag concepts: name the 1-3 knowledge areas this commit touches.)
MSG
            # Record last commit time for ACTIVITY-PULSE
            date +%s > "$STATE_DIR/last_commit_ts"
            exit 2
        fi
    fi

    # ── SESSION-END: git merge / wrap-up (keep, but simpler) ──
    IS_SESSION_END=false
    case "$CMD_FIRST" in
        git)
            case "${CMD:-}" in
                *"git merge"*) IS_SESSION_END=true ;;
            esac
            ;;
        *wrap-up*|*wrap_up*|*progress_report*) IS_SESSION_END=true ;;
    esac

    if [ "$IS_SESSION_END" = "true" ]; then
        # Mark session as completed in state
        ${EARS_STATE} end 2>/dev/null || true

        if ! rate_limited "session_end"; then
            # ── Distillation nudge: check if enough new entries accumulated ──
            DISTILL_HINT=""
            KNOWLEDGE_ROOT="${REPO_ROOT:-$TRACE_DIR}"
            if [ -n "$KNOWLEDGE_ROOT" ] && [ -d "$KNOWLEDGE_ROOT/knowledge" ]; then
                # Find most recent distillation date from knowledge/ files
                LAST_DISTILL=""
                for KF in "$KNOWLEDGE_ROOT"/knowledge/*.md; do
                    [ -f "$KF" ] || continue
                    [ "$(basename "$KF")" = "README.md" ] && continue
                    D=$(grep -m1 'Last distilled:' "$KF" 2>/dev/null | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')
                    if [ -n "$D" ]; then
                        [ -z "$LAST_DISTILL" ] && LAST_DISTILL="$D"
                        [[ "$D" > "$LAST_DISTILL" ]] && LAST_DISTILL="$D"
                    fi
                done
                # Count EARS entries in trace files modified after knowledge/README.md
                NEW_ENTRIES=0
                REF_FILE="$KNOWLEDGE_ROOT/knowledge/README.md"
                if [ -f "$REF_FILE" ]; then
                    while IFS= read -r TF; do
                        [ -f "$TF" ] || continue
                        N=$(grep -c '### EARS' "$TF" 2>/dev/null || true)
                        NEW_ENTRIES=$((NEW_ENTRIES + N))
                    done < <(find "$KNOWLEDGE_ROOT" -name 'trace.md' -newer "$REF_FILE" 2>/dev/null)
                fi
                if [ "$NEW_ENTRIES" -ge 5 ]; then
                    DISTILL_HINT="

[EARS] ~${NEW_ENTRIES} trace entries since last distillation (${LAST_DISTILL:-unknown}).
Consider running /distill to extract new patterns into knowledge/."
                fi
            fi

            cat >&2 <<MSG
[EARS] Session wrap-up in $CTX_NAME.

Before finishing, append to $(trace_path):
### EARS — Session End ($(date '+%Y-%m-%d %H:%M'))
<!-- concepts: concept1, concept2 -->
- Accomplished: <what got done this session>
- Next session: <what you'd tell the next agent working here>
- Open issues: <anything unresolved>
(Tag concepts: name the knowledge areas touched this session. Skip if nothing notable.)${DISTILL_HINT}

[EARS] Memory check: did anything break (pitfall), get decided (decision),
or become a confirmed workflow (pattern) this session? If so, write it to
.claude/memory/ — don't wait for /reflect, it may never run.
MSG
            exit 2
        fi
    fi

    exit 0
fi

# ============================================================
# WRITE/EDIT path: STUCK detection + no-trace reminder
# ============================================================

if [ "$TOOL" = "Write" ] || [ "$TOOL" = "Edit" ]; then

    # No trace.md reminder (once per 20 min)
    if [ -z "$TRACE_DIR" ]; then
        if ! rate_limited "no_trace"; then
            echo "[EARS] $CTX_NAME: No trace.md found. Create one at $REPO_ROOT/trace.md." >&2
            exit 2
        fi
        exit 0
    fi

    # Only track files inside the project
    CONTEXT_DIR="${TRACE_DIR:-$REPO_ROOT}"
    case "${FILE:-}" in
        "$CONTEXT_DIR"/*) ;;
        *) exit 0 ;;
    esac

    # ── STUCK detection: same file edited 4+ times recently ──
    EDIT_LOG="$STATE_DIR/recent_edits.log"
    echo "$(date +%s) ${FILE:-unknown}" >> "$EDIT_LOG"

    # Update session state heartbeat and edit count
    ${EARS_STATE} bump edits 2>/dev/null || true

    # Keep only last 20 entries
    if [ -f "$EDIT_LOG" ] && [ "$(wc -l < "$EDIT_LOG")" -gt 20 ]; then
        tail -20 "$EDIT_LOG" > "$EDIT_LOG.tmp" && mv "$EDIT_LOG.tmp" "$EDIT_LOG"
    fi

    if [ -n "$FILE" ]; then
        SAME_COUNT=$(grep -cF "$FILE" "$EDIT_LOG" 2>/dev/null || echo 0)
        if [ "$SAME_COUNT" -ge 4 ]; then
            if ! rate_limited "stuck"; then
                SHORT=$(basename "$FILE")
                cat >&2 <<MSG
[EARS] Thrashing? $SHORT edited $SAME_COUNT times recently in $CTX_NAME.

If you're stuck, append to $(trace_path):
### EARS — Stuck ($(date '+%Y-%m-%d %H:%M'))
<!-- concepts: concept1, concept2 -->
- Context: <what task/goal were you working on?>
- Goal: <what you're trying to achieve>
- Obstacle: <what's not working>
- Tried: <approaches attempted so far>
(Tag concepts: name the knowledge areas relevant to this obstacle.)
(If you're not stuck, carry on — this resets automatically.)
MSG
                # Reset so we don't immediately re-trigger
                > "$EDIT_LOG"
                exit 2
            fi
        fi
    fi

    # ── ACTIVITY-PULSE: 30+ min of edits without commit or trace update ──
    # Catches long stretches of decisive work that never trigger ERROR→FIX
    # or STUCK, but contain important decisions worth recording.
    if [ -n "$TRACE_DIR" ]; then
        LAST_COMMIT_TS=$(cat "$STATE_DIR/last_commit_ts" 2>/dev/null || echo 0)
        LAST_TRACE_TS=$(stat -c '%Y' "$TRACE_DIR/trace.md" 2>/dev/null || echo 0)
        LAST_ACTIVITY=$(( LAST_COMMIT_TS > LAST_TRACE_TS ? LAST_COMMIT_TS : LAST_TRACE_TS ))
        NOW=$(date +%s)
        ELAPSED=$(( NOW - LAST_ACTIVITY ))

        # Only fire if 30+ min since last commit or trace update,
        # AND there have been at least 5 edits (active work, not idle)
        EDIT_COUNT=$(wc -l < "$EDIT_LOG" 2>/dev/null || echo 0)
        if [ "$ELAPSED" -gt 1800 ] && [ "$EDIT_COUNT" -ge 5 ]; then
            if ! rate_limited "activity_pulse"; then
                cat >&2 <<MSG
[EARS] Active for ${ELAPSED}s without a trace update in $CTX_NAME.

Pause and append to $(trace_path):
### EARS — Progress ($(date '+%Y-%m-%d %H:%M'))
<!-- concepts: concept1, concept2 -->
Any decisions, discoveries, or dead ends worth capturing? What have you
been working on and why? (Tag concepts: name the relevant knowledge areas.)
Skip if nothing notable.
MSG
                exit 2
            fi
        fi
    fi
fi

exit 0
